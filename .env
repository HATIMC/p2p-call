# HTTP port (Mac/localhost dev)
PORT=3000
# HTTPS port (required for iPhone / any non-localhost device)
HTTPS_PORT=3443

# ── User TTL ──────────────────────────────────────────────────────────────
# Fixed lifetime of a registration in seconds, counted from creation.
# After this time the user disappears from the directory — no extensions.
# Set to 0 to disable expiry (users persist until server restart).
USER_TTL_SECONDS=60

# TURN — leave blank while developing
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
